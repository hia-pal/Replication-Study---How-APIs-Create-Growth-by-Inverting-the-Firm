        "\n",
        "# Create event time using correct column names\n",
        "adopt_info = df[df['post_api'] == 1].groupby('firm_id')['quarter'].min().reset_index()\n",
        "adopt_info.columns = ['firm_id', 'adopt_quarter']\n",
        "print(f\"Found {len(adopt_info)} adopting firms\")\n",
