        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "print(\"=\" * 70)\n",
        "print(\"GENERATING SYNTHETIC COMPUSTAT DATA WITH REALISTIC P-VALUES\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "# ============================================================================\n",
        "# 1. PARAMETERS\n",
        "# ============================================================================\n",
        "\n",
        "n_firms = 500\n",
        "n_quarters = 55\n",
        "n_obs = n_firms * n_quarters\n",
        "\n",
        "# ============================================================================\n",
        "# 2. FIRM CHARACTERISTICS\n",
        "# ============================================================================\n",
        "\n",
        "firm_id = np.repeat(np.arange(n_firms), n_quarters)\n",
        "quarter_id = np.tile(np.arange(n_quarters), n_firms)\n",
        "year = 2007 + (quarter_id // 4)\n",
        "quarter_in_year = (quarter_id % 4) + 1\n",
        "\n",
        "# Time-invariant firm characteristics\n",
        "firm_size = np.random.lognormal(mean=5, sigma=1.5, size=n_firms)\n",
        "industry = np.random.choice(['Services', 'Transport', 'Manufacturing', 'Retail', 'Other'],\n",
        "                            size=n_firms, p=[0.25, 0.10, 0.30, 0.15, 0.20])\n",
        "is_tech = np.random.choice([0, 1], size=n_firms, p=[0.85, 0.15])\n",
        "\n",
        "# Expand to panel\n",
        "firm_size_panel = np.repeat(firm_size, n_quarters)\n",
        "industry_panel = np.repeat(industry, n_quarters)\n",
        "is_tech_panel = np.repeat(is_tech, n_quarters)\n",
        "\n",
        "# ============================================================================\n",
        "# 3. MACRO SHOCKS\n",
        "# ============================================================================\n",
        "\n",
        "gfc_shock = np.where((quarter_id >= 7) & (quarter_id <= 9), -0.30, 0)\n",
        "covid_shock = np.where(quarter_id >= 51, -0.15, 0)\n",
        "time_trend = np.linspace(0, 0.5, n_quarters)\n",
        "\n",
        "# ============================================================================\n",
        "# 4. API ADOPTION\n",
        "# ============================================================================\n",
        "\n",
        "adoption_base_prob = {\n",
        "    'Services': 0.25,\n",
        "    'Transport': 0.18,\n",
        "    'Manufacturing': 0.08,\n",
        "    'Retail': 0.12,\n",
        "    'Other': 0.05\n",
        "}\n",
        "\n",
        "adoption_prob = np.array([adoption_base_prob[ind] * (1.5 if tech else 1)\n",
        "                          for ind, tech in zip(industry, is_tech)])\n",
        "\n",
        "adoption_quarter = np.full(n_firms, np.nan)\n",
        "for f in range(n_firms):\n",
        "    if np.random.random() < adoption_prob[f]:\n",
        "        adoption_quarter[f] = np.random.randint(5, 45)\n",
        "\n",
        "has_api = np.zeros(n_obs)\n",
        "for f in range(n_firms):\n",
        "    if not np.isnan(adoption_quarter[f]):\n",
        "        mask = (firm_id == f) & (quarter_id >= adoption_quarter[f])\n",
        "        has_api[mask] = 1\n",
        "\n",
        "time_since_adoption = np.full(n_obs, np.nan)\n",
        "for f in range(n_firms):\n",
        "    if not np.isnan(adoption_quarter[f]):\n",
        "        mask = (firm_id == f)\n",
        "        ts = quarter_id[mask] - adoption_quarter[f]\n",
        "        time_since_adoption[mask] = ts\n",
        "time_since_adoption = np.where(time_since_adoption < 0, 0, time_since_adoption)\n",
        "time_since_adoption = np.nan_to_num(time_since_adoption, nan=0)\n",
        "\n",
        "# ============================================================================\n",
        "# 5. BASE MARKET VALUE (WITH MORE REALISTIC NOISE)\n",
        "# ============================================================================\n",
        "\n",
        "# Increased noise to make p-values realistic (not exactly 0)\n",
        "base_log_mv = (\n",
        "    np.log(firm_size_panel) * 0.8 +\n",
        "    (industry_panel == 'Services') * 0.5 +\n",
        "    (industry_panel == 'Transport') * 0.3 +\n",
        "    is_tech_panel * 0.4 +\n",
        "    time_trend[quarter_id] +\n",
        "    gfc_shock +\n",
        "    covid_shock +\n",
        "    np.random.normal(0, 0.35, n_obs)  # Increased from 0.3 to 0.35\n",
        ")\n",
        "\n",
        "# ============================================================================\n",
        "# 6. TREATMENT EFFECT (WITH REALISTIC HETEROGENEITY)\n",
        "# ============================================================================\n",
        "\n",
        "treatment_effect = np.zeros(n_obs)\n",
        "\n",
        "for f in range(n_firms):\n",
        "    if not np.isnan(adoption_quarter[f]):\n",
        "        mask = (firm_id == f) & (has_api == 1)\n",
        "        t = time_since_adoption[mask]\n",
        "\n",
        "        # Paper's effect: +38.7% at 16 years\n",
        "        effect = 0.387 * (1 - np.exp(-0.045 * t))\n",
        "\n",
        "        # ADD REALISTIC HETEROGENEITY (not too little, not too much)\n",
        "        # Some firms benefit more, some less - but most benefit\n",
        "        firm_effect = np.random.normal(1.0, 0.15, len(effect))  # 85% to 115% of base effect\n",
        "        effect = effect * firm_effect\n",
        "\n",
        "        # Add quarter-level noise\n",
        "        quarter_noise = np.random.normal(0, 0.02, len(effect))\n",
        "        effect = effect + quarter_noise\n",
        "\n",
        "        treatment_effect[mask] = effect\n",
        "\n",
        "log_market_value = base_log_mv + treatment_effect\n",
        "market_value = np.exp(log_market_value)\n",
        "\n",
        "# ============================================================================\n",
        "# 7. ASSETS\n",
        "# ============================================================================\n",
        "\n",
        "base_log_assets = np.log(firm_size_panel) + time_trend[quarter_id] * 0.3 + np.random.normal(0, 0.25, n_obs)\n",
        "assets_treatment = treatment_effect * 0.3\n",
        "log_assets = base_log_assets + assets_treatment\n",
        "assets = np.exp(log_assets)\n",
        "tobins_q = market_value / assets\n",
        "\n",
        "# ============================================================================\n",
        "# 8. CREATE DATAFRAME\n",
        "# ============================================================================\n",
        "\n",
        "df_compustat = pd.DataFrame({\n",
        "    'firm_id': firm_id,\n",
        "    'quarter': quarter_id,\n",
        "    'year': year,\n",
        "    'quarter_in_year': quarter_in_year,\n",
        "    'industry': industry_panel,\n",
        "    'is_tech': is_tech_panel,\n",
        "    'has_api': has_api,\n",
        "    'post_api': has_api,\n",
        "    'time_since_adoption': time_since_adoption,\n",
        "    'market_value': market_value,\n",
        "    'log_market_value': log_market_value,\n",
        "    'assets': assets,\n",
        "    'log_assets': log_assets,\n",
        "    'tobins_q': tobins_q,\n",
        "})\n",
        "\n",
        "# ============================================================================\n",
        "# 9. RUN REGRESSION WITH PROPER P-VALUE DISPLAY\n",
        "# ============================================================================\n",
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"VALIDATION: Difference-in-Differences Regression\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "import statsmodels.formula.api as smf\n",
        "import statsmodels.api as sm\n",
        "\n",
        "# Sample for faster computation\n",
        "sample_firms = np.random.choice(df_compustat['firm_id'].unique(), size=min(200, n_firms), replace=False)\n",
        "df_sample = df_compustat[df_compustat['firm_id'].isin(sample_firms)].copy()\n",
        "\n",
        "# Add fixed effects as categorical\n",
        "df_sample['firm_id_c'] = df_sample['firm_id'].astype('category')\n",
        "df_sample['quarter_c'] = df_sample['quarter'].astype('category')\n",
        "\n",
        "# Run regression\n",
        "model = smf.ols(\"log_market_value ~ has_api + C(firm_id_c) + C(quarter_c)\", data=df_sample).fit()\n",
        "\n",
        "# Get p-value (ensuring it's not displayed as 0.000000)\n",
        "p_value = model.pvalues['has_api']\n",
        "coef = model.params['has_api']\n",
        "ci_low, ci_high = model.conf_int().loc['has_api']\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"REGRESSION RESULTS\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"has_api coefficient: {coef:.4f}\")\n",
        "print(f\"p-value: {p_value:.6f}\")  # This will show something like 0.000234\n",
        "print(f\"95% CI: [{ci_low:.4f}, {ci_high:.4f}]\")\n",
        "\n",
        "# Interpret p-value realistically\n",
        "if p_value < 0.0001:\n",
        "    print(f\"\\n✓ p = {p_value:.2e} - Very strong evidence (matches paper)\")\n",
        "elif p_value < 0.001:\n",
        "    print(f\"\\n✓ p = {p_value:.4f} - Strongly significant\")\n",
        "elif p_value < 0.01:\n",
        "    print(f\"\\n✓ p = {p_value:.4f} - Significant\")\n",
        "elif p_value < 0.05:\n",
        "    print(f\"\\n✓ p = {p_value:.4f} - Marginally significant\")\n",
        "else:\n",
        "    print(f\"\\n✗ p = {p_value:.4f} - Not significant\")\n",
        "\n",
        "# Also show the t-statistic for realism\n",
        "t_stat = coef / model.bse['has_api']\n",
        "print(f\"t-statistic: {t_stat:.2f}\")\n",
        "print(f\"Degrees of freedom: {model.df_resid}\")\n",
        "\n",
        "# ============================================================================\n",
        "# 10. SAVE DATA\n",
        "# ============================================================================\n",
        "\n",
        "df_compustat.to_csv('synthetic_compustat.csv', index=False)\n",
        "\n",
        "print(\"\\n\" + \"=\" * 70)\n",
        "print(\"✅ DATA GENERATION COMPLETE!\")\n",
        "print(\"=\" * 70)\n",
        "print(f\"\\nSaved: synthetic_compustat.csv\")\n",
        "print(f\"  - {len(df_compustat):,} observations\")\n",
        "print(f\"  - {df_compustat['firm_id'].nunique()} firms\")\n",
        "print(f\"  - {df_compustat['has_api'].sum():,} API observations ({df_compustat['has_api'].mean()*100:.1f}%)\")"
      ]
