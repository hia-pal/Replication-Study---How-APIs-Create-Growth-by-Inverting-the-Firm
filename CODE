        "\n",
        "# Simple pre-post comparison with matching\n",
        "treated_firms = df[df['post_api'] == 1]['gvkey'].unique()\n",
        "control_firms = df[df['post_api'] == 0]['gvkey'].unique()\n",
        "\n",
        "# Pre-period (first 20 quarters) and post-period (last 20 quarters)\n",
        "pre_mask = df['quarter'] < 20\n",
        "post_mask = df['quarter'] >= 35\n",
        "\n",
        "# Calculate averages\n",
        "treated_pre = df[(df['gvkey'].isin(treated_firms)) & pre_mask]['log_mktcap'].mean()\n",
        "treated_post = df[(df['gvkey'].isin(treated_firms)) & post_mask]['log_mktcap'].mean()\n",
        "control_pre = df[(df['gvkey'].isin(control_firms)) & pre_mask]['log_mktcap'].mean()\n",
        "control_post = df[(df['gvkey'].isin(control_firms)) & post_mask]['log_mktcap'].mean()\n",
        "\n",
        "# ATT\n",
        "att = (treated_post - treated_pre) - (control_post - control_pre)\n",
        "\n",
        "# Bootstrap for standard error\n",
        "np.random.seed(42)\n",
        "n_boot = 1000\n",
        "boot_att = []\n",
        "\n",
        "for _ in range(n_boot):\n",
        "    boot_treated = np.random.choice(treated_firms, size=len(treated_firms), replace=True)\n",
        "    boot_control = np.random.choice(control_firms, size=min(len(control_firms), len(treated_firms)), replace=True)\n",
        "\n",
        "    bt_pre = df[df['gvkey'].isin(boot_treated) & pre_mask]['log_mktcap'].mean()\n",
        "    bt_post = df[df['gvkey'].isin(boot_treated) & post_mask]['log_mktcap'].mean()\n",
        "    bc_pre = df[df['gvkey'].isin(boot_control) & pre_mask]['log_mktcap'].mean()\n",
        "    bc_post = df[df['gvkey'].isin(boot_control) & post_mask]['log_mktcap'].mean()\n",
        "\n",
        "    boot_att.append((bt_post - bt_pre) - (bc_post - bc_pre))\n",
        "\n",
        "boot_att = np.array(boot_att)\n",
