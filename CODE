        "print(f\"\\n{'Regression-Based DiD:':30} {model.params.get('post_treatment', np.nan):.4f}\")\n",
        "if 'post_treatment' in model.pvalues:\n",
        "    print(f\"{'P-value:':30} {model.pvalues['post_treatment']:.4f}\")\n",
        "print(f\"{'R-squared:':30} {model.rsquared:.4f}\")\n",
        "\n",
