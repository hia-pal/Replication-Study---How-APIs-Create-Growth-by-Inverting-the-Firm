        "\n",
        "event_stats['normalized'] = event_stats['mean_log_mktcap'] - pre_mean\n",
        "event_stats['ci_lo'] = event_stats['normalized'] - 1.96 * event_stats['se']\n",
        "event_stats['ci_hi'] = event_stats['normalized'] + 1.96 * event_stats['se']\n",
        "\n",
        "# Ensure the omitted period (t=-1) is set to 0\n",
