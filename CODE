        "    print(\"  No API firms found, using empty dataset\")\n",
        "\n",
        "# Create synthetic breach data\n",
        "print(\"\\nCreating synthetic breach data...\")\n",
        "breach = pd.DataFrame({\n",
        "    'gvkey': np.random.choice(df['firm_id'].unique(), min(50, df['firm_id'].nunique()), replace=False),\n",
