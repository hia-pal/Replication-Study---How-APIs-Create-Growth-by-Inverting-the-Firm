        "df_event = df.merge(adopt_info, on='firm_id', how='left')\n",
        "\n",
        "# Only keep firms that adopted APIs\n",
        "df_event = df_event[df_event['adopt_quarter'].notna()].copy()\n",
        "\n",
        "# Calculate relative time\n",
        "df_event['rel_time'] = df_event['quarter'] - df_event['adopt_quarter']\n",
        "\n",
        "# Filter to -8 to +8 window\n",
        "df_event = df_event[(df_event['rel_time'] >= -8) & (df_event['rel_time'] <= 8)]\n",
        "\n",
        "print(f\"Event study sample: {len(df_event)} observations\")\n",
        "print(f\"Relative time range: {df_event['rel_time'].min()} to {df_event['rel_time'].max()}\")\n",
        "\n",
        "# Calculate mean and standard error for each relative time period\n",
        "event_stats = df_event.groupby('rel_time')['log_market_value'].agg(['mean', 'std', 'count']).reset_index()\n",
        "event_stats.columns = ['rel_time', 'mean_log_mktcap', 'std_log_mktcap', 'n']\n",
