        "\"\"\"\n",
        "COMPLETE TABLES 1-4 - EXACT PAPER FORMAT (FIXED - No Missing Files)\n",
        "Benzell, Hersh & Van Alstyne (2024) - Replication with Synthetic Data\n",
        "\n",
        "Formats match:\n",
        "- Table 1: Two-Way Fixed Effects (6 columns)\n",
        "- Table 2: Synthetic Control ATT\n",
        "- Table 3: 2SLS IV Results (9 columns)\n",
        "- Table 4: DiD with Asset Controls (6 columns)\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# ============================================================================\n",
        "# CREATE SYNTHETIC DATA FILES IF MISSING\n",
        "# ============================================================================\n",
        "\n",
        "print(\"=\" * 70)\n",
        "print(\"LOADING & CREATING SYNTHETIC DATA\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "# Load compustat data\n",
        "df = pd.read_csv(\"synthetic_compustat.csv\")\n",
        "print(f\"Loaded compustat: {len(df):,} observations\")\n",
        "\n",
        "# Create synthetic programmableweb data if file doesn't exist\n",
        "try:\n",
        "    pw = pd.read_csv(\"synthetic_programmableweb.csv\")\n",
        "    print(f\"Loaded ProgrammableWeb: {len(pw)} rows\")\n",
        "except FileNotFoundError:\n",
        "    print(\"Creating synthetic ProgrammableWeb data...\")\n",
        "    np.random.seed(42)\n",
        "\n",
        "    # Get API-adopting firms\n",
        "    api_firms = df[df['has_api'] == 1]['firm_id'].unique()\n",
        "    n_apis = min(len(api_firms), 100)\n",
        "\n",
        "    if n_apis > 0:\n",
        "        pw = pd.DataFrame({\n",
        "            'api_id': [f\"api_{i:03d}\" for i in range(n_apis)],\n",
        "            'gvkey': np.random.choice(api_firms, n_apis, replace=False),\n",
        "            'industry': df[df['firm_id'].isin(api_firms)]['industry'].value_counts().index[0] if len(api_firms) > 0 else 'Services',\n",
        "            'followers': np.random.exponential(100, n_apis).astype(int),\n",
        "            'betweenness': np.random.exponential(0.01, n_apis),\n",
        "            'connected_apps': ['app1|app2|app3'] * n_apis\n",
        "        })\n",
        "    else:\n",
        "        pw = pd.DataFrame(columns=['api_id', 'gvkey', 'followers', 'betweenness'])\n",
        "\n",
        "    print(f\"  Created {len(pw)} synthetic API records\")\n",
        "    pw.to_csv(\"synthetic_programmableweb.csv\", index=False)\n",
        "    print(\"  Saved: synthetic_programmableweb.csv\")\n",
        "\n",
        "# ============================================================================\n",
        "# PREPARE DATA\n",
        "# ============================================================================\n",
        "\n",
        "# Prepare main data\n",
        "df['year'] = 2007 + (df['quarter'] // 4)\n",
        "df['quarter_in_year'] = (df['quarter'] % 4) + 1\n",
        "df['date_q'] = pd.to_datetime(df['year'].astype(str) + '-Q' + df['quarter_in_year'].astype(str))\n",
        "\n",
        "# Rename columns\n",
        "df = df.rename(columns={\n",
        "    'firm_id': 'gvkey',\n",
        "    'log_market_value': 'log_mktcap',\n",
        "    'has_api': 'has_pub_api',\n",
        "    'log_assets': 'log_assets'\n",
        "})\n",
        "df['post_api'] = df['has_pub_api'].astype(int)\n",
        "\n",
        "# Create log_assets if missing\n",
        "if 'log_assets' not in df.columns and 'assets' in df.columns:\n",
        "    df['log_assets'] = np.log(df['assets'])\n",
        "elif 'log_assets' not in df.columns:\n",
        "    # Create synthetic log_assets\n",
        "    np.random.seed(42)\n",
        "    df['log_assets'] = np.log(df['market_value']) * 0.7 + np.random.normal(0, 0.3, len(df))\n",
        "\n",
        "# Create is_top_api flag (top 20 firms by followers)\n",
        "if len(pw) > 0 and 'followers' in pw.columns:\n",
        "    top_firms = pw.nlargest(min(20, len(pw)), 'followers')['gvkey'].unique()\n",
        "    df['is_top_api'] = df['gvkey'].isin(top_firms).astype(int)\n",
        "else:\n",
        "    # Create synthetic top API flag based on market value\n",
        "    api_firms = df[df['post_api'] == 1]['gvkey'].unique()\n",
        "    top_api_firms = np.random.choice(api_firms, min(20, len(api_firms)), replace=False)\n",
        "    df['is_top_api'] = df['gvkey'].isin(top_api_firms).astype(int)\n",
        "\n",
        "# Industry to SIC mapping\n",
        "industry_to_sic = {'Services': 7, 'Transport': 4, 'Manufacturing': 3, 'Retail': 5, 'Other': 9}\n",
        "df['sic1'] = df['industry'].map(industry_to_sic)\n",
        "df['sic4'] = df['sic1'] * 1000\n",
        "df['is_comp_svcs'] = (df['sic4'] == 7000)  # Services as proxy for computer services\n",
        "\n",
        "# Adoption year\n",
        "adopt_info = df[df['post_api'] == 1].groupby('gvkey')['year'].min().reset_index()\n",
        "adopt_info.columns = ['gvkey', 'adopt_year']\n",
        "df = df.merge(adopt_info, on='gvkey', how='left')\n",
        "\n",
        "# Fill missing adopt_year for non-adopters with a large number\n",
        "df['adopt_year'] = df['adopt_year'].fillna(9999)\n",
        "\n",
        "print(f\"Unique firms: {df['gvkey'].nunique()}\")\n",
        "print(f\"API adopters: {df['post_api'].sum():,} obs ({df['post_api'].mean()*100:.1f}%)\\n\")\n",
        "\n",
        "# ============================================================================\n",
        "# TABLE 1: Two-Way Fixed Effects (Paper Format)\n",
        "# ============================================================================\n",
        "\n",
        "print(\"=\" * 70)\n",
        "print(\"TABLE 1: Two-Way Fixed Effect Estimations\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "import statsmodels.formula.api as smf\n",
        "\n",
        "def stars(p):\n",
        "    if pd.isna(p): return ''\n",
        "    if p < 0.001: return '***'\n",
        "    if p < 0.01: return '**'\n",
        "    if p < 0.05: return '*'\n",
        "    return ''\n",
        "\n",
        "def run_twfe(data, y_var='log_mktcap', treat_var='post_api'):\n",
        "    \"\"\"Run two-way fixed effects regression\"\"\"\n",
        "    try:\n",
        "        # Ensure required columns exist\n",
        "        if y_var not in data.columns:\n",
        "            return np.nan, np.nan, np.nan, 0, 0, 0\n",
        "\n",
        "        data = data.dropna(subset=[y_var, 'gvkey', 'quarter'])\n",
        "        if len(data) == 0:\n",
        "            return np.nan, np.nan, np.nan, 0, 0, 0\n",
        "\n",
        "        # Use sample if too large\n",
        "        if len(data) > 50000:\n",
        "            data = data.sample(50000, random_state=42)\n",
        "\n",
        "        data['gvkey_c'] = data['gvkey'].astype('category')\n",
        "        data['quarter_c'] = data['quarter'].astype('category')\n",
        "\n",
        "        model = smf.ols(f\"{y_var} ~ {treat_var} + C(gvkey_c) + C(quarter_c)\", data=data)\n",
        "        res = model.fit()\n",
        "\n",
        "        coef = res.params.get(treat_var, np.nan)\n",
        "        se = res.bse.get(treat_var, np.nan)\n",
        "        pval = res.pvalues.get(treat_var, np.nan)\n",
        "        nobs = len(data)\n",
        "        n_firms = data['gvkey'].nunique()\n",
        "        n_adopters = data[data[treat_var] == 1]['gvkey'].nunique() if treat_var in data.columns else 0\n",
        "\n",
        "        return coef, se, pval, nobs, n_firms, n_adopters\n",
        "    except Exception as e:\n",
        "        print(f\"  Error in TWFE: {e}\")\n",
        "        return np.nan, np.nan, np.nan, 0, 0, 0\n",
        "\n",
        "# Column 1: All firms\n",
        "c1 = run_twfe(df, 'log_mktcap', 'post_api')\n",
        "\n",
        "# Column 2: Excluding top-20 API firms\n",
        "top20_firms = df[df['is_top_api'] == 1]['gvkey'].unique()\n",
        "d2 = df[~df['gvkey'].isin(top20_firms)]\n",
        "c2 = run_twfe(d2, 'log_mktcap', 'post_api')\n",
        "\n",
        "# Column 3: Excluding industries with <1% API adoption\n",
        "industry_adoption = df.groupby('industry')['post_api'].mean()\n",
        "low_adoption_industries = industry_adoption[industry_adoption < 0.01].index\n",
        "d3 = df[~df['industry'].isin(low_adoption_industries)]\n",
        "c3 = run_twfe(d3, 'log_mktcap', 'post_api')\n",
        "\n",
        "# Column 4: Excluding computer services (SIC 7370 proxy)\n",
        "d4 = df[~df['is_comp_svcs']]\n",
        "c4 = run_twfe(d4, 'log_mktcap', 'post_api')\n",
        "\n",
        "# Column 5: API opened < 2012\n",
        "d5 = df[df['adopt_year'] < 2012]\n",
        "c5 = run_twfe(d5, 'log_mktcap', 'post_api') if len(d5) > 0 else (np.nan, np.nan, np.nan, 0, 0, 0)\n",
        "\n",
        "# Column 6: API opened >= 2012\n",
        "d6 = df[df['adopt_year'] >= 2012]\n",
        "c6 = run_twfe(d6, 'log_mktcap', 'post_api') if len(d6) > 0 else (np.nan, np.nan, np.nan, 0, 0, 0)\n",
        "\n",
        "results_t1 = [c1, c2, c3, c4, c5, c6]\n",
        "\n",
        "# Print Table 1\n",
        "col_labels = ['(1)', '(2)', '(3)', '(4)', '(5)', '(6)']\n",
        "col_headers = ['All Firms', 'Excl. Top-20', 'Excl. Low-API\\nIndustries', 'Excl. Computer\\nServices', 'API Year\\n< 2012', 'API Year\\n≥ 2012']\n",
        "\n",
        "print(\"\\n\" + \"=\" * 95)\n",
        "print(\"Table 1. Two-Way Fixed Effect Estimations of the Effect of API\")\n",
        "print(\"         Adoption on Log Market Value\")\n",
        "print(\"=\" * 95)\n",
        "\n",
        "# Print column headers\n",
        "header_line = \" \" * 25\n",
        "for i, h in enumerate(col_headers):\n",
        "    header_line += f\"{col_labels[i]:>14}\"\n",
        "print(header_line)\n",
        "\n",
        "header_line2 = \" \" * 25\n",
        "for h in col_headers:\n",
        "    header_line2 += f\"{h.split(chr(10))[0]:>14}\"\n",
        "print(header_line2)\n",
        "print(\"-\" * 95)\n",
        "\n",
        "# Print coefficients\n",
        "coef_line = f\"{'Post × API':25}\"\n",
        "se_line = \" \" * 25\n",
        "for coef, se, pval, _, _, _ in results_t1:\n",
        "    if not np.isnan(coef):\n",
        "        coef_line += f\"{coef:>13.3f}{stars(pval)}\"\n",
        "        se_line += f\"({se:>11.4f})\"\n",
        "    else:\n",
        "        coef_line += f\"{'---':>14}\"\n",
        "        se_line += f\"{'---':>14}\"\n",
        "print(coef_line)\n",
        "print(se_line)\n",
        "\n",
        "# Print FE rows\n",
        "print(f\"{'Firm FE':25}\" + \"\".join([f\"{'Yes':>14}\" for _ in results_t1]))\n",
        "print(f\"{'Quarter FE':25}\" + \"\".join([f\"{'Yes':>14}\" for _ in results_t1]))\n",
        "\n",
        "# Print observations\n",
        "obs_line = f\"{'Observations':25}\"\n",
        "for coef, se, pval, nobs, _, _ in results_t1:\n",
        "    obs_line += f\"{nobs:>14,}\" if not np.isnan(nobs) and nobs > 0 else f\"{'---':>14}\"\n",
        "print(obs_line)\n",
        "\n",
        "# Print firms\n",
        "firm_line = f\"{'Firms':25}\"\n",
        "for coef, se, pval, nobs, n_firms, _ in results_t1:\n",
        "    firm_line += f\"{n_firms:>14,}\" if not np.isnan(n_firms) and n_firms > 0 else f\"{'---':>14}\"\n",
        "print(firm_line)\n",
        "\n",
        "print(\"-\" * 95)\n",
        "print(\"*** p<0.001, ** p<0.01, * p<0.05\")\n",
        "print(\"Standard errors in parentheses.\")\n",
        "print(\"=\" * 95)\n",
        "\n",
        "# Save\n",
