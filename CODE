        "\n",
        "# Prepare data\n",
        "df_did = df.copy()\n",
        "\n",
        "# Define pre and post periods\n",
        "df_did['period'] = 'pre'\n",
        "df_did.loc[df_did['year'] >= 2015, 'period'] = 'post'\n",
        "\n",
        "# Get treated firms (those that ever adopted API)\n",
        "treated_firms = df_did[df_did['post_api'] == 1]['firm_id'].unique()\n",
        "df_did['treated'] = df_did['firm_id'].isin(treated_firms).astype(int)\n",
        "\n",
        "# Calculate means by group\n",
        "results_did = []\n",
        "for industry in df_did['industry'].unique():\n",
        "    subset = df_did[df_did['industry'] == industry]\n",
        "\n",
        "    treated_pre = subset[(subset['treated'] == 1) & (subset['period'] == 'pre')]['log_mktcap'].mean()\n",
        "    treated_post = subset[(subset['treated'] == 1) & (subset['period'] == 'post')]['log_mktcap'].mean()\n",
        "    control_pre = subset[(subset['treated'] == 0) & (subset['period'] == 'pre')]['log_mktcap'].mean()\n",
        "    control_post = subset[(subset['treated'] == 0) & (subset['period'] == 'post')]['log_mktcap'].mean()\n",
        "\n",
        "    did = (treated_post - treated_pre) - (control_post - control_pre)\n",
        "    results_did.append({\n",
        "        'industry': industry,\n",
        "        'did_estimate': did,\n",
        "        'treated_pre': treated_pre,\n",
        "        'treated_post': treated_post,\n",
        "        'control_pre': control_pre,\n",
        "        'control_post': control_post\n",
        "    })\n",
        "\n",
        "# Overall DiD\n",
        "overall_treated_pre = df_did[(df_did['treated'] == 1) & (df_did['period'] == 'pre')]['log_mktcap'].mean()\n",
        "overall_treated_post = df_did[(df_did['treated'] == 1) & (df_did['period'] == 'post')]['log_mktcap'].mean()\n",
        "overall_control_pre = df_did[(df_did['treated'] == 0) & (df_did['period'] == 'pre')]['log_mktcap'].mean()\n",
        "overall_control_post = df_did[(df_did['treated'] == 0) & (df_did['period'] == 'post')]['log_mktcap'].mean()\n",
        "overall_did = (overall_treated_post - overall_treated_pre) - (overall_control_post - overall_control_pre)\n",
        "\n",
        "# Run regression-based DiD\n",
        "df_did['post_treatment'] = (df_did['period'] == 'post').astype(int) * df_did['treated']\n",
        "model = smf.ols(\"log_mktcap ~ treated + post_treatment + C(industry) + C(year)\", data=df_did).fit()\n",
        "\n",
