        "\n",
        "# Load only the compustat dataset (other files are synthetic or created on-the-fly)\n",
        "df = pd.read_csv(\"synthetic_compustat.csv\")\n",
        "\n",
        "print(f\"Compustat: {df.shape[0]:,} rows, {df.shape[1]} columns\")\n",
        "\n",
        "# Create synthetic ProgrammableWeb-like data if needed\n",
        "print(\"\\nCreating synthetic ProgrammableWeb data...\")\n",
        "np.random.seed(42)\n",
        "\n",
        "# Get unique firms that have APIs\n",
        "api_firms = df[df['has_api'] == 1]['firm_id'].unique()\n",
        "n_apis = min(len(api_firms), 100)  # Use up to 100 APIs\n",
        "\n",
        "if n_apis > 0:\n",
        "    pw = pd.DataFrame({\n",
        "        'api_id': [f\"api_{i}\" for i in range(n_apis)],\n",
        "        'gvkey': np.random.choice(api_firms, n_apis, replace=False),\n",
        "        'industry': np.random.choice(['Services', 'Transport', 'Manufacturing', 'Retail', 'Other'], n_apis),\n",
