        "    'gvkey': np.random.choice(df['firm_id'].unique(), min(100, df['firm_id'].nunique()), replace=False),\n",
        "    'has_private_api': np.random.choice([0, 1], min(100, df['firm_id'].nunique()), p=[0.7, 0.3])\n",
        "})\n",
        "print(f\"  Created {len(private)} synthetic private API records\")\n",
        "\n",
